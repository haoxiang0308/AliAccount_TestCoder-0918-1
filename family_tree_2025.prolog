% База фактов о семье

% Предикаты: родитель(Родитель, Ребенок).
родитель(иван, мария).
родитель(иван, алексей).
родитель(ольга, мария).
родитель(ольга, алексей).
родитель(алексей, дмитрий).
родитель(алексей, анастасия).
родитель(екатерина, дмитрий).
родитель(екатерина, анастасия).

% Предикаты: пол(Имя, Пол).
пол(иван, мужской).
пол(ольга, женский).
пол(алексей, мужской).
пол(мария, женский).
пол(екатерина, женский).
пол(дмитрий, мужской).
пол(анастасия, женский).

% Правила

% бабушка(Бабушка, Внук) - если X родитель Y, а Y родитель Z, то X бабушка или дедушка Z.
% Для бабушки добавим проверку пола.
бабушка(X, Z) :-
    родитель(X, Y),
    родитель(Y, Z),
    пол(X, женский).

% дедушка(Дедушка, Внук)
дедушка(X, Z) :-
    родитель(X, Y),
    родитель(Y, Z),
    пол(X, мужской).

% сестра(Сестра, Брат_или_Сестра)
сестра(X, Y) :-
    родитель(Z, X),
    родитель(Z, Y),
    пол(X, женский),
    X \= Y.

% брат(Брат, Брат_или_Сестра)
брат(X, Y) :-
    родитель(Z, X),
    родитель(Z, Y),
    пол(X, мужской),
    X \= Y.