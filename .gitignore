```
# Generated .gitignore for TypeScript project

# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js
*.tsbuildinfo

# Logs
*.log

# Environment
.env
.env.local
.env.*

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python (if mixed project)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/

# Temporary files
*.tmp
*.temp
*.bak

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```